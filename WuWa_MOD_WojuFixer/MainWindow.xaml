<Window x:Class="WuWa_MOD_WojuFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Woju - WuWa MOD Fixer v3.2"
        Height="560" Width="820"
        WindowStartupLocation="CenterScreen" Icon="Woju.ico" Opacity="0.995">
    <Window.Background>
        <ImageBrush ImageSource="/thumb-1920-1406017.jpg"/>
    </Window.Background>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Woju: Select your mod folder (only files named mod.ini in that folder and subfolders will be processed)."
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="FolderTextBox"
                     IsReadOnly="True"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Margin="0,0,10,0"/>

            <Button x:Name="BrowseButton"
                    Grid.Column="1"
                    Content="Browse..."
                    Width="120"
                    Height="30"
                    Click="BrowseButton_Click"/>
        </Grid>

        <CheckBox x:Name="StableTexturesCheckBox"
                  Grid.Row="2"
                  Content="Apply StableTextures injection (Need Latest RabbitFX)"
                  Margin="0,0,0,10"
                  FontWeight="SemiBold"
                  Background="White"
                  BorderBrush="#FF757575" Checked="StableTexturesCheckBox_Checked"/>

        <!-- NEW: link buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left">

            <Button x:Name="BrowseWojuModsButton"
                    Content="Browse Woju Mods"
                    MinWidth="160"
                    Height="30"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Click="BrowseWojuModsButton_Click"
                    Background="White"/>

            <Button x:Name="DownloadRabbitFxButton"
                    Content="Download Latest RabbitFX"
                    MinWidth="210"
                    Height="30"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Click="DownloadRabbitFxButton_Click"
                    Background="White"/>

            <Button x:Name="WojuKofiButton"
                    Content="Woju Ko-fi"
                    MinWidth="120"
                    Height="30"
                    Padding="12,6"
                    Click="WojuKofiButton_Click"
                    Background="White"/>
        </StackPanel>

        <GroupBox Grid.Row="4" Header="Log">
            <Grid>
                <TextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Padding="8"
                         Background="#CC111111"
                         Foreground="White"
                         CaretBrush="White"
                         BorderBrush="#FF444444"/>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="RunButton"
                    Content="Run Fix"
                    Width="120"
                    Height="34"
                    Click="RunButton_Click"
                    Background="White"/>

            <Button x:Name="ClearLogButton"
                    Grid.Column="1"
                    Content="Clear Log"
                    Width="120"
                    Height="34"
                    Margin="10,0,0,0"
                    Click="ClearLogButton_Click"
                    Background="White"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Foreground="Gray" Text="User: Woju25" Margin="0,0,12,0"/>
                <TextBlock Foreground="Gray" Text="Requires hashes.json next to the .exe"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>